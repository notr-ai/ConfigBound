{
  "name": "@config-bound/cli",
  "version": "0.2.0",
  "description": "CLI tool for ConfigBound schema export and management",
  "keywords": [
    "cli",
    "config",
    "schema",
    "export",
    "configbound"
  ],
  "author": "Robert Keyser",
  "license": "MIT",
  "type": "module",
  "bin": {
    "configbound": "./bin/configbound.js"
  },
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist coverage .turbo",
    "dev": "tsx src/main.ts",
    "test": "NODE_OPTIONS='--experimental-vm-modules' jest",
    "test:dev": "NODE_OPTIONS='--experimental-vm-modules' jest --watch",
    "test:coverage": "NODE_OPTIONS='--experimental-vm-modules' jest --coverage",
    "lint": "eslint src/**/*.ts --fix",
    "lint:ci": "eslint src/**/*.ts",
    "format": "prettier --write --config ../../.config/.prettierrc --ignore-path ../../.config/.prettierignore src/**/*.ts",
    "format:ci": "prettier --check --config ../../.config/.prettierrc --ignore-path ../../.config/.prettierignore src/**/*.ts"
  },
  "dependencies": {
    "@config-bound/core": "workspace:*",
    "@config-bound/schema-export": "workspace:*",
    "@nestjs/common": "^11.1.18",
    "@nestjs/core": "^11.1.18",
    "chalk": "^4.1.2",
    "esbuild-register": "^3.6.0",
    "nest-commander": "^3.15.0",
    "reflect-metadata": "^0.2.2",
    "ts-morph": "^24.0.0",
    "tsx": "catalog:"
  },
  "devDependencies": {
    "@config-bound/eslint-config": "workspace:*",
    "@config-bound/typescript-config": "workspace:*",
    "@nestjs/testing": "^11.1.18",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "jest": "catalog:",
    "markdown-table": "^3.0.4",
    "rimraf": "catalog:",
    "ts-jest": "catalog:",
    "typescript": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/notr-ai/ConfigBound"
  }
}
