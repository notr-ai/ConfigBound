{
  "name": "@config-bound/docs",
  "version": "0.0.0",
  "private": true,
  "description": "ConfigBound documentation site",
  "scripts": {
    "docs:api": "typedoc",
    "docs:cli": "node ../../scripts/generate-cli-docs.mjs",
    "docs:build": "npm run docs:api && npm run docs:cli && vitepress build",
    "docs:dev": "npm run docs:api && npm run docs:cli && vitepress dev --host",
    "docs:preview": "vitepress preview --host",
    "clean": "rimraf .vitepress/dist reference/api reference/cli .turbo"
  },
  "devDependencies": {
    "@config-bound/config-bound": "*",
    "@config-bound/schema-export": "*",
    "@config-bound/typescript-config": "*",
    "@shikijs/twoslash": "2.5.0",
    "@shikijs/vitepress-twoslash": "^2.5.0",
    "rimraf": "^6.1.3",
    "typedoc": "^0.28.19",
    "typedoc-plugin-markdown": "^4.11.0",
    "vitepress": "^1.6.4",
    "vitepress-plugin-llms": "^1.12.0"
  }
}
