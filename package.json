{
  "name": "config-bound-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "npm@10.5.0",
  "workspaces": [
    "examples",
    "apps/cli",
    "apps/docs",
    "packages/config-bound",
    "packages/eslint-config",
    "packages/nestjs",
    "packages/schema-export",
    "packages/typescript-config"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/notr-ai/ConfigBound"
  },
  "scripts": {
    "build": "turbo run build",
    "docs:build": "turbo run docs:build --filter=@config-bound/docs",
    "docs:dev": "turbo run docs:dev --filter=@config-bound/docs",
    "docs:preview": "turbo run docs:preview --filter=@config-bound/docs",
    "clean": "rimraf .turbo",
    "clean:all": "turbo run clean",
    "check": "npm run format:ci && npm run lint:ci && npm run test",
    "format": "turbo run format && npm run lint:markdown",
    "format:ci": "turbo run format:ci && npm run lint:markdown:ci",
    "lint": "turbo run lint && npm run lint:markdown",
    "lint:ci": "turbo run lint:ci && npm run lint:markdown:ci",
    "lint:markdown": "markdownlint-cli2 --fix --config .config/.markdownlint-cli2.jsonc",
    "lint:markdown:ci": "markdownlint-cli2 --config .config/.markdownlint-cli2.jsonc",
    "docs:check": "npm run lint:markdown && npm run docs:build && npm run docs:links",
    "docs:links": "lychee --config .config/lychee.toml --root-dir \"$(pwd)/apps/docs\" './apps/docs/**/*.md'",
    "test": "turbo run test",
    "test:dev": "turbo run test:dev",
    "test:coverage": "turbo run test:coverage",
    "examples:envVar": "turbo run examples:envVar --filter=examples",
    "examples:file": "turbo run examples:file --filter=examples",
    "examples:static": "turbo run examples:static --filter=examples",
    "examples:export": "turbo run examples:export --filter=examples",
    "examples:export:json": "turbo run examples:export:json --filter=examples",
    "examples:export:yaml": "turbo run examples:export:yaml --filter=examples",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepare": "husky",
    "scan": "grype dir:. --fail-on medium --config .config/.grype.yaml"
  },
  "devDependencies": {
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "^9.39.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.46.3",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-jest": "^29.0.1",
    "eslint-plugin-turbo": "^2.6.0",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "jest-runner-groups": "^2.2.0",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "3.8.2",
    "rimraf": "^6.1.0",
    "ts-jest": "^29.4.5",
    "turbo": "^2.9.6",
    "typescript": "^6.0.0",
    "typescript-eslint": "^8.51.8"
  }
}
