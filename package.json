{
  "name": "config-bound-monorepo",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@11.2.2",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/notr-ai/ConfigBound.git"
  },
  "scripts": {
    "build": "turbo run build",
    "docs:build": "turbo run docs:build --filter=@config-bound/docs",
    "docs:dev": "turbo run docs:dev --filter=@config-bound/docs",
    "docs:preview": "turbo run docs:preview --filter=@config-bound/docs",
    "clean": "rimraf .turbo",
    "clean:all": "turbo run clean",
    "typecheck": "turbo run typecheck",
    "publint": "publint packages/core && publint packages/nestjs && publint packages/schema-export",
    "attw": "attw --pack packages/core && attw --pack packages/nestjs && attw --pack packages/schema-export",
    "check": "pnpm run format:ci && pnpm run lint:ci && pnpm run typecheck && pnpm run test",
    "format": "turbo run format && pnpm run lint:markdown",
    "format:ci": "turbo run format:ci && pnpm run lint:markdown:ci",
    "lint": "turbo run lint && pnpm run lint:markdown",
    "lint:ci": "turbo run lint:ci && pnpm run lint:markdown:ci",
    "lint:markdown": "markdownlint-cli2 --fix --config .config/.markdownlint-cli2.jsonc",
    "lint:markdown:ci": "markdownlint-cli2 --config .config/.markdownlint-cli2.jsonc",
    "docs:check": "pnpm run lint:markdown && pnpm run docs:vale && pnpm run docs:build && pnpm run docs:links",
    "docs:links": "lychee --config .config/lychee.toml --root-dir \"$(pwd)/apps/docs\" './apps/docs/**/*.md'",
    "docs:vale": "vale --config=./.config/.vale.ini ./apps/docs/**/*.md",
    "test": "turbo run test",
    "test:dev": "turbo run test:dev",
    "test:coverage": "turbo run test:coverage",
    "examples": "turbo run examples --filter=examples",
    "examples:run": "turbo run --filter=examples",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish",
    "prepare": "husky",
    "scan": "grype dir:. --fail-on medium --config .config/.grype.yaml",
    "new:bind": "node scripts/new-bind.mjs"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.3",
    "@changesets/cli": "^2.30.0",
    "@eslint/js": "catalog:",
    "@types/jest": "catalog:",
    "@types/node": "catalog:",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-jest": "catalog:",
    "eslint-plugin-turbo": "catalog:",
    "globals": "catalog:",
    "husky": "catalog:",
    "jest-runner-groups": "catalog:",
    "markdownlint-cli2": "^0.22.0",
    "prettier": "catalog:",
    "publint": "^0.3.21",
    "rimraf": "catalog:",
    "ts-jest": "catalog:",
    "tsdown": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  }
}
