{
  "name": "@config-bound/config-bound",
  "version": "0.3.0",
  "description": "A config registration library",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/notr-ai/ConfigBound.git"
  },
  "type": "module",
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist coverage",
    "test": "jest --config jest.config.cjs",
    "lint": "eslint src/**/*.ts --fix",
    "lint:ci": "eslint src/**/*.ts",
    "format": "prettier --write --config ../../.config/.prettierrc --ignore-path ../../.config/.prettierignore src/**/*.ts",
    "format:ci": "prettier --check --config ../../.config/.prettierrc --ignore-path ../../.config/.prettierignore src/**/*.ts"
  },
  "main": "./dist/configBound.cjs",
  "module": "./dist/configBound.mjs",
  "types": "./dist/configBound.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/configBound.d.mts",
        "default": "./dist/configBound.mjs"
      },
      "require": {
        "types": "./dist/configBound.d.cts",
        "default": "./dist/configBound.cjs"
      }
    },
    "./section": {
      "import": {
        "types": "./dist/section/section.d.mts",
        "default": "./dist/section/section.mjs"
      },
      "require": {
        "types": "./dist/section/section.d.cts",
        "default": "./dist/section/section.cjs"
      }
    },
    "./element": {
      "import": {
        "types": "./dist/element/element.d.mts",
        "default": "./dist/element/element.mjs"
      },
      "require": {
        "types": "./dist/element/element.d.cts",
        "default": "./dist/element/element.cjs"
      }
    },
    "./bind": {
      "import": {
        "types": "./dist/bind/bind.d.mts",
        "default": "./dist/bind/bind.mjs"
      },
      "require": {
        "types": "./dist/bind/bind.d.cts",
        "default": "./dist/bind/bind.cjs"
      }
    },
    "./bind/configValueProvider": {
      "import": {
        "types": "./dist/bind/configValueProvider.d.mts",
        "default": "./dist/bind/configValueProvider.mjs"
      },
      "require": {
        "types": "./dist/bind/configValueProvider.d.cts",
        "default": "./dist/bind/configValueProvider.cjs"
      }
    },
    "./bind/binds/envVar": {
      "import": {
        "types": "./dist/bind/binds/envVar.d.mts",
        "default": "./dist/bind/binds/envVar.mjs"
      },
      "require": {
        "types": "./dist/bind/binds/envVar.d.cts",
        "default": "./dist/bind/binds/envVar.cjs"
      }
    },
    "./bind/binds/file": {
      "import": {
        "types": "./dist/bind/binds/file.d.mts",
        "default": "./dist/bind/binds/file.mjs"
      },
      "require": {
        "types": "./dist/bind/binds/file.d.cts",
        "default": "./dist/bind/binds/file.cjs"
      }
    },
    "./bind/binds/static": {
      "import": {
        "types": "./dist/bind/binds/static.d.mts",
        "default": "./dist/bind/binds/static.mjs"
      },
      "require": {
        "types": "./dist/bind/binds/static.d.cts",
        "default": "./dist/bind/binds/static.cjs"
      }
    },
    "./utilities": {
      "import": {
        "types": "./dist/utilities/index.d.mts",
        "default": "./dist/utilities/index.mjs"
      },
      "require": {
        "types": "./dist/utilities/index.d.cts",
        "default": "./dist/utilities/index.cjs"
      }
    },
    "./binds/env": {
      "import": {
        "types": "./dist/bind/binds/envVar.d.mts",
        "default": "./dist/bind/binds/envVar.mjs"
      },
      "require": {
        "types": "./dist/bind/binds/envVar.d.cts",
        "default": "./dist/bind/binds/envVar.cjs"
      }
    },
    "./binds/file": {
      "import": {
        "types": "./dist/bind/binds/file.d.mts",
        "default": "./dist/bind/binds/file.mjs"
      },
      "require": {
        "types": "./dist/bind/binds/file.d.cts",
        "default": "./dist/bind/binds/file.cjs"
      }
    },
    "./binds/static": {
      "import": {
        "types": "./dist/bind/binds/static.d.mts",
        "default": "./dist/bind/binds/static.mjs"
      },
      "require": {
        "types": "./dist/bind/binds/static.d.cts",
        "default": "./dist/bind/binds/static.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "engines": { "node": ">=20" },
  "typedocOptions": {
    "entryPoints": [
      "./src/configBound.ts",
      "./src/section/section.ts",
      "./src/element/element.ts",
      "./src/bind/bind.ts",
      "./src/bind/configValueProvider.ts",
      "./src/bind/binds/envVar.ts",
      "./src/bind/binds/file.ts",
      "./src/bind/binds/static.ts",
      "./src/utilities/errors.ts",
      "./src/utilities/logger.ts"
    ],
    "tsconfig": "./tsconfig.json"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "keywords": [
    "config",
    "configuration",
    "environment",
    "settings"
  ],
  "author": "Robert Keyser",
  "license": "MIT",
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@config-bound/eslint-config": "workspace:*",
    "@eslint/js": "catalog:",
    "@types/jest": "catalog:",
    "@types/js-yaml": "^4.0.9",
    "@typescript-eslint/eslint-plugin": "catalog:",
    "eslint": "catalog:",
    "eslint-config-prettier": "catalog:",
    "eslint-plugin-jest": "catalog:",
    "eslint-plugin-turbo": "catalog:",
    "globals": "catalog:",
    "husky": "catalog:",
    "jest-runner-groups": "catalog:",
    "prettier": "catalog:",
    "rimraf": "catalog:",
    "ts-jest": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:",
    "typescript-eslint": "catalog:"
  },
  "dependencies": {
    "js-yaml": "^4.1.0",
    "jsonc-parser": "^3.3.1",
    "zod": "^4.4.1"
  }
}
