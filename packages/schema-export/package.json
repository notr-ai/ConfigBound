{
  "name": "@config-bound/schema-export",
  "version": "0.1.2",
  "description": "Schema export utilities for ConfigBound configuration library",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "sideEffects": false,
  "files": ["dist", "README.md", "LICENSE", "CHANGELOG.md"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "clean": "rimraf dist",
    "test": "jest",
    "lint": "eslint src/**/*.ts --fix",
    "lint:ci": "eslint src/**/*.ts",
    "format": "prettier --write --config ../../.config/.prettierrc --ignore-path ../../.config/.prettierignore src/**/*.ts",
    "format:ci": "prettier --check --config ../../.config/.prettierrc --ignore-path ../../.config/.prettierignore src/**/*.ts"
  },
  "keywords": [
    "config",
    "configuration",
    "schema",
    "export",
    "json",
    "yaml",
    "documentation"
  ],
  "author": "Robert Keyser",
  "license": "MIT",
  "peerDependencies": {
    "zod": "^4.4.1"
  },
  "dependencies": {
    "@config-bound/core": "workspace:*",
    "js-yaml": "^4.1.0"
  },
  "devDependencies": {
    "@config-bound/eslint-config": "workspace:*",
    "@config-bound/typescript-config": "workspace:*",
    "@types/jest": "catalog:",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "jest": "catalog:",
    "rimraf": "catalog:",
    "ts-jest": "catalog:",
    "typescript": "catalog:",
    "zod": "catalog:"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "typedocOptions": {
    "entryPoints": ["./src/index.ts"],
    "tsconfig": "./tsconfig.typedoc.json",
    "exclude": ["**/*.spec.ts"]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/notr-ai/ConfigBound.git"
  }
}
