{
  "$schema": "https://turbo.build/schema.json",
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "docs:build": {
      "dependsOn": ["^build"],
      "outputs": [".vitepress/dist/**", "reference/api/**", "reference/cli/**"],
      "inputs": ["**/*.md", ".vitepress/**", "typedoc.json", "package.json"]
    },
    "docs:vale": {
      "dependsOn": ["docs:build"],
      "outputs": [],
      "inputs": ["**/*.md", ".vitepress/dist/**", "package.json"]
    },
    "docs:dev": {
      "dependsOn": ["^build"],
      "cache": false,
      "persistent": true
    },
    "docs:preview": {
      "dependsOn": ["docs:build"],
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    },
    "lint": {
      "outputs": []
    },
    "lint:ci": {
      "outputs": []
    },
    "format": {
      "outputs": []
    },
    "format:ci": {
      "outputs": []
    },
    "test": {
      "dependsOn": ["build"],
      "inputs": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx", "**/*.spec.ts"],
      "outputs": []
    },
    "test:dev": {
      "dependsOn": ["build"],
      "inputs": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx", "**/*.spec.ts"],
      "outputs": [],
      "cache": false,
      "persistent": true
    },
    "test:coverage": {
      "dependsOn": ["build"],
      "inputs": ["**/*.ts", "**/*.tsx", "**/*.js", "**/*.jsx", "**/*.spec.ts"],
      "outputs": ["coverage/**"]
    },
    "examples": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": false
    },
    "examples:envVar": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": false
    },
    "examples:file": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": false
    },
    "examples:static": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": false
    },
    "examples:export": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": false
    },
    "examples:export:json": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": false
    },
    "examples:export:yaml": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": false
    },
    "app:env": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": false
    },
    "app:files": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": false
    },
    "app:static": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": false
    },
    "export": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": false
    },
    "export:json": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": false
    },
    "export:yaml": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": false
    },
    "export:env": {
      "dependsOn": ["build"],
      "outputs": [],
      "cache": false
    }
  }
}
