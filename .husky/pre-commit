#!/usr/bin/env bash
#
# This file is used to run the pre-commit hooks for the project.
# If changes are made to this file, update the documentation in CONTRIBUTING.md.

# Exit on any error
set -e

echo "⚙️ Running pre-commit hooks..."

echo "🔒 Checking pnpm-lock.yaml..."
pnpm list --depth=0 >/dev/null 2>&1 || {
  echo "❌ pnpm-lock.yaml is out of sync with package.json"
  echo "   Run 'pnpm install' to update it"
  exit 1
}

echo "📝 Checking Formatting..."
pnpm run format:ci || {
  echo "💡 To fix formatting issues, run: "
  echo "      pnpm run format"
  exit 1
}

echo "🔎 Checking Linting..."
pnpm run lint:ci || {
  echo "💡 To fix linting issues, run: "
  echo "      pnpm run lint"
  exit 1
}

echo "✅ Pre-commit hooks completed successfully!"
