{
  "name": "examples",
  "version": "0.0.0",
  "scripts": {
    "build": "tsc",
    "clean": "rimraf dist",
    "examples": "npm run app:env && npm run app:files && npm run app:static && npm run export && npm run export:json && npm run export:yaml && npm run export:env",
    "app:env": "EXAMPLE_APP_PORT=8080 EXAMPLE_DATABASE_PASSWORD=supersecret123 EXAMPLE_API_KEY=abc1234xyz node dist/envVar/envVarBindExample.js",
    "app:files": "node dist/file/fileBindExample.js",
    "app:static": "node dist/static/staticBindExample.js",
    "export": "node dist/exportExample.js",
    "export:json": "node dist/exportExample.js json",
    "export:yaml": "node dist/exportExample.js yaml",
    "export:env": "node dist/exportExample.js env"
  },
  "author": "Robert Keyser",
  "license": "MIT",
  "description": "Examples for ConfigBound",
  "private": true,
  "dependencies": {
    "@config-bound/config-bound": "workspace:*",
    "@config-bound/schema-export": "workspace:*"
  }
}
